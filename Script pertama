-- ================== UTILITY FUNCTIONS ==================
local function getCharacter(player)
    return player.Character
end

local function getRoot(player)
    local char = getCharacter(player)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(player)
    local char = getCharacter(player)
    return char and char:FindFirstChild("Humanoid")
end

local function getAlivePlayers()
    local alive = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and getCharacter(plr) and getHumanoid(plr) and getHumanoid(plr).Health > 0 then
            table.insert(alive, plr)
        end
    end
    return alive
end

-- ================== ESP SYSTEM ==================
local function createESP(targetPlayer)
    if not DrawingLib then return end
    
    local espData = {
        Player = targetPlayer,
        Box = DrawingLib.new("Square"),
        Name = DrawingLib.new("Text"),
        Distance = DrawingLib.new("Text"),
        HealthBar = DrawingLib.new("Square"),
        HealthBg = DrawingLib.new("Square")
    }
    
    -- Configure ESP objects
    espData.Box.Thickness = 2
    espData.Box.Filled = false
    espData.Box.Color = Color3.fromRGB(255, 255, 255)
    espData.Box.Visible = false
    
    espData.Name.Size = 13
    espData.Name.Center = true
    espData.Name.Outline = true
    espData.Name.Color = Color3.fromRGB(255, 255, 255)
    espData.Name.Visible = false
    
    espData.Distance.Size = 12
    espData.Distance.Center = true
    espData.Distance.Outline = true
    espData.Distance.Color = Color3.fromRGB(200, 200, 200)
    espData.Distance.Visible = false
    
    espData.HealthBar.Size = Vector2.new(2, 0)
    espData.HealthBar.Filled = true
    espData.HealthBar.Color = Color3.fromRGB(0, 255, 0)
    espData.HealthBar.Visible = false
    
    espData.HealthBg.Size = Vector2.new(3, 0)
    espData.HealthBg.Filled = true
    espData.HealthBg.Color = Color3.fromRGB(40, 40, 40)
    espData.HealthBg.Visible = false
    
    Features.ESP.Objects[targetPlayer] = espData
end

local function removeESP(targetPlayer)
    local espData = Features.ESP.Objects[targetPlayer]
    if espData then
        pcall(function()
            espData.Box:Remove()
            espData.Name:Remove()
            espData.Distance:Remove()
            espData.HealthBar:Remove()
            espData.HealthBg:Remove()
        end)
        Features.ESP.Objects[targetPlayer] = nil
    end
end

local function updateESP()
    if not Features.ESP.Enabled or not DrawingLib then return end
    
    local camera = workspace.CurrentCamera
    local localRoot = getRoot(player)
    
    for targetPlayer, espData in pairs(Features.ESP.Objects) do
        pcall(function()
            local character = getCharacter(targetPlayer)
            if not character or not character.Parent then
                removeESP(targetPlayer)
                return
            end
            
            local root = getRoot(targetPlayer)
            local humanoid = getHumanoid(targetPlayer)
            local head = character:FindFirstChild("Head")
            
            if not root or not head or not humanoid or humanoid.Health <= 0 then
                espData.Box.Visible = false
                espData.Name.Visible = false
                espData.Distance.Visible = false
                espData.HealthBar.Visible = false
                espData.HealthBg.Visible = false
                return
            end
            
            local rootPos, rootVisible = camera:WorldToViewportPoint(root.Position)
            local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
            
            if not rootVisible then
                espData.Box.Visible = false
                espData.Name.Visible = false
                espData.Distance.Visible = false
                espData.HealthBar.Visible = false
                espData.HealthBg.Visible = false
                return
            end
            
            local distance = localRoot and (localRoot.Position - root.Position).Magnitude or 0
            
            if distance > Features.ESP.Settings.MaxDistance then
                espData.Box.Visible = false
                espData.Name.Visible = false
                espData.Distance.Visible = false
                espData.HealthBar.Visible = false
                espData.HealthBg.Visible = false
                return
            end
            
            local boxHeight = math.abs(headPos.Y - rootPos.Y)
            local boxWidth = boxHeight * 0.55
            
            -- Team color
            local espColor = targetPlayer.Team and targetPlayer.Team.TeamColor.Color or Color3.fromRGB(255, 255, 255)
            if Features.Aimbot.TeamCheck and targetPlayer.Team == player.Team then
                espColor = Color3.fromRGB(0, 255, 0) -- Friendly
            end
            
            -- Update Box
            if Features.ESP.Settings.ShowBox then
                espData.Box.Size = Vector2.new(boxWidth, boxHeight)
                espData.Box.Position = Vector2.new(rootPos.X - boxWidth/2, rootPos.Y - boxHeight)
                espData.Box.Color = espColor
                espData.Box.Visible = true
            else
                espData.Box.Visible = false
            end
            
            -- Update Name
            if Features.ESP.Settings.ShowName then
                espData.Name.Text = targetPlayer.Name
                espData.Name.Position = Vector2.new(rootPos.X, rootPos.Y - boxHeight - 14)
                espData.Name.Color = espColor
                espData.Name.Visible = true
            else
                espData.Name.Visible = false
            end
            
            -- Update Distance
            if Features.ESP.Settings.ShowDistance then
                espData.Distance.Text = string.format("%.0f studs", distance)
                espData.Distance.Position = Vector2.new(rootPos.X, rootPos.Y + 2)
                espData.Distance.Visible = true
            else
                espData.Distance.Visible = false
            end
            
            -- Update Health
            if Features.ESP.Settings.ShowHealth and humanoid then
                local healthPercent = humanoid.Health / humanoid.MaxHealth
                local healthHeight = boxHeight * healthPercent
                
                espData.HealthBg.Size = Vector2.new(3, boxHeight)
                espData.HealthBg.Position = Vector2.new(rootPos.X - boxWidth/2 - 6, rootPos.Y - boxHeight)
                espData.HealthBg.Visible = true
                
                espData.HealthBar.Size = Vector2.new(2, healthHeight)
                espData.HealthBar.Position = Vector2.new(rootPos.X - boxWidth/2 - 5.5, rootPos.Y - healthHeight)
                espData.HealthBar.Color = Color3.fromRGB(
                    255 * (1 - healthPercent),
                    255 * healthPercent,
                    0
                )
                espData.HealthBar.Visible = true
            else
                espData.HealthBar.Visible = false
                espData.HealthBg.Visible = false
            end
        end)
    end
end

-- ================== AIMBOT SYSTEM ==================
local function getClosestPlayerToCursor()
    if not Features.Aimbot.Enabled then return nil end
    
    local mouse = player:GetMouse()
    local camera = workspace.CurrentCamera
    local closest = nil
    local closestDist = Features.Aimbot.FOV
    
    for _, target in ipairs(getAlivePlayers()) do
        if Features.Aimbot.TeamCheck and target.Team == player.Team then
            continue
        end
        
        local targetPart = getCharacter(target):FindFirstChild(Features.Aimbot.TargetPart) or getRoot(target)
        if not targetPart then continue end
        
        -- Wall check
        if Features.Aimbot.WallCheck then
            local rayOrigin = camera.CFrame.Position
            local rayDir = (targetPart.Position - rayOrigin).Unit * 1000
            local ray = Ray.new(rayOrigin, rayDir)
            local hit, _ = workspace:FindPartOnRay(ray, getCharacter(player))
            if hit and hit.Parent ~= getCharacter(target) then
                continue
            end
        end
        
        local screenPos, visible = camera:WorldToViewportPoint(targetPart.Position)
        if not visible then continue end
        
        local mousePos = Vector2.new(mouse.X, mouse.Y)
        local targetPos = Vector2.new(screenPos.X, screenPos.Y)
        local dist = (mousePos - targetPos).Magnitude
        
        if dist < closestDist then
            closestDist = dist
            closest = targetPart
        end
    end
    
    return closest
end

local function aimAt(targetPart)
    if not targetPart or not Features.Aimbot.Enabled then return end
    
    local camera = workspace.CurrentCamera
    local targetPos = targetPart.Position + Vector3.new(
        math.random(-5, 5) / 100,
        math.random(-5, 5) / 100,
        math.random(-5, 5) / 100
    )
    
    local lookAt = CFrame.new(camera.CFrame.Position, targetPos)
    
    if Features.Aimbot.Smoothness > 0 then
        camera.CFrame = camera.CFrame:Lerp(lookAt, Features.Aimbot.Smoothness)
    else
        camera.CFrame = lookAt
    end
end

